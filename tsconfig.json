{
  "compilerOptions": {
    // ─── File Layout ───
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@config/*": ["src/config/*"],
      "@modules/*": ["src/modules/*"],
      "@shared/*": ["src/shared/*"]
    },
    // "outDir": "./dist",

    // ─── Decorators (Essenciais para o TypeORM) ───
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    
    // ─── Environment Settings ───
    "module": "commonjs",
    "target": "esnext",
    "types": ["node"],
    
    // ─── Other Outputs ───
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "ignoreDeprecations": "6.0",

    // ─── Stricter Typechecking Options ───
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,

    // ─── Recommended Options ───
    "strict": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  }
}