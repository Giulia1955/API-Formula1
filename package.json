{
  "name": "api-formula-1",
  "version": "1.0.0",
  "description": "API backend para gerenciamento de dados da Fórmula 1",
  "main": "src/shared/http/server.ts",
  "scripts": {
    "dev": "node node_modules/ts-node-dev/lib/bin.js --inspect -r tsconfig-paths/register --transpile-only --ignore-watch node_modules src/shared/http/server.ts",
    "typeorm": "node node_modules/ts-node/dist/bin.js -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:run": "npm run typeorm -- migration:run -d src/shared/typeorm/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate -d src/shared/typeorm/data-source.ts"
  },
  "author": "Giulia_1955",
  "license": "ISC",
  "dependencies": {
    "@mui/joy": "^5.0.0-beta.52",
    "bcryptjs": "^3.0.3",
    "celebrate": "^15.0.3",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "handlebars": "^4.7.9",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "ts-node-dev": "^2.0.0",
    "typeorm": "^0.3.28",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/joi": "^17.2.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^8.0.1",
    "tsconfig-paths": "^4.2.0"
  }
}
